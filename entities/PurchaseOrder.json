{
  "name": "PurchaseOrder",
  "type": "object",
  "properties": {
    "store_id": {
      "type": "string"
    },
    "po_number": {
      "type": "string"
    },
    "vendor_id": {
      "type": "string"
    },
    "vendor_name": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number",
      "default": 0
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Pending",
        "Approved",
        "Received",
        "Cancelled"
      ],
      "default": "Draft"
    },
    "notes": {
      "type": "string"
    },
    "timestamp_wib": {
      "type": "string"
    }
  },
  "required": [
    "store_id",
    "vendor_id"
  ]
}