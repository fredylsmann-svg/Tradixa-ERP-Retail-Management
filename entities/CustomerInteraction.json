{
  "name": "CustomerInteraction",
  "type": "object",
  "properties": {
    "store_id": { "type": "string" },
    "customer_id": { "type": "string" },
    "customer_name": { "type": "string" },
    "interaction_type": { "type": "string", "enum": ["Email Sent", "Email Opened", "Link Clicked", "SMS Sent", "SMS Opened", "WhatsApp Sent", "Purchase", "Call", "Meeting"], "default": "Email Sent" },
    "campaign_id": { "type": "string" },
    "campaign_name": { "type": "string" },
    "metadata": { "type": "object", "description": "Data tambahan (link yang diklik, subject email, dll)" },
    "timestamp_wib": { "type": "string" }
  },
  "required": ["store_id", "customer_id", "interaction_type"]
}
